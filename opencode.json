{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "plugin": [
    "oh-my-openagent"
  ],
  "provider": {
    "openai": {
      "options": {
        "headerTimeout": 60000,
        "timeout": 300000,
        "chunkTimeout": 60000
      }
    }
  }
}
