  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "reasoningEffort": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "reasoningEffort": "high"
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "reasoningEffort": "high"
    },
    "artistry": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "reasoningEffort": "high"
    },
    "tiny-edit": {
      "model": "openai/gpt-5.4-mini",
      "variant": "medium",
      "reasoningEffort": "low"
    },
    "major-refactor": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "reasoningEffort": "high"
    },
    "research-fast": {
      "model": "openai/gpt-5.4-mini-fast",
      "variant": "medium",
      "reasoningEffort": "low"
    },
    "comment-edit": {
      "model": "openai/gpt-5.4-mini-fast",
      "variant": "medium",
      "reasoningEffort": "low"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "variant": "medium",
      "reasoningEffort": "low"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini",
      "variant": "medium",
      "reasoningEffort": "medium"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "reasoningEffort": "high"
    },
    "writing": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "reasoningEffort": "medium"
    }
  },
  "background_task": {
    "providerConcurrency": {
      "openai": 1
    },
    "modelConcurrency": {
      "openai/gpt-5.5": 1,
      "openai/gpt-5.4-mini-fast": 2,
      "openai/gpt-5.4-mini": 2
    }
  },
  "team_mode": {
    "enabled": true,
    "tmux_visualization": true,
    "max_parallel_members": 4,
    "max_members": 8,
    "max_messages_per_run": 10000,
    "max_wall_clock_minutes": 120,
    "max_member_turns": 500,
    "message_payload_max_bytes": 32768,
    "recipient_unread_max_bytes": 262144,
    "mailbox_poll_interval_ms": 3000
  },
  "disabled_providers": [
    "deepseek"
  ]
}
